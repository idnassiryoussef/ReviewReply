# Copy this file to .env.local and add your API keys.
# Do NOT commit your actual API keys to source control.

# Use Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: override default Claude model
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key

# Admin access (comma-separated emails)
ADMIN_EMAILS=admin@example.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Paddle Checkout (client-side overlay)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=pdl_ctm_your_client_token
NEXT_PUBLIC_PADDLE_PRICE_ID=pri_your_monthly_price_id
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Paddle server-side API (optional, for backend-created transactions)
PADDLE_API_KEY=pdl_live_or_sdbx_api_key
PADDLE_PRICE_ID=pri_your_monthly_price_id

# Public app URL used by billing routes
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional footer signature
NEXT_PUBLIC_BUILT_BY_NAME=idnassir93

# Contact form email (Resend)
RESEND_API_KEY=re_xxxxxxxx
